{
  "name": "clearpaste",
  "version": "1.0.0",
  "description": "Lightweight clipboard manager for macOS with automatic text cleaning",
  "main": "./out/main/index.js",
  "author": "ClearPaste",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^8.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.1.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.clearpaste.app",
    "productName": "ClearPaste",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "resources/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "sign": false,
      "identity": null
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}